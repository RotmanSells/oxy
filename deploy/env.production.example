# Copy to /opt/oxy/api/.env on the server and fill real secrets.
PORT=3000
NODE_ENV=production

# Public site URL. Example: https://example.com
SITE_URL=https://YOUR_DOMAIN
CORS_ORIGIN=https://YOUR_DOMAIN

# Telegram
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# AI provider. HydraAI is OpenAI-compatible.
OPENAI_API_KEY=YOUR_HYDRA_OR_OPENAI_KEY
OPENAI_MODEL=minimax-m2
OPENAI_BASE_URL=https://api.hydraai.ru/v1

# SQLite storage. Keep it outside release folders.
DB_PATH=/var/lib/oxy/leads.db

# Uploaded site photos. Keep it outside release folders.
UPLOAD_DIR=/var/lib/oxy/uploads

# Required for protected content/media write endpoints.
ADMIN_SECRET=CHANGE_TO_LONG_RANDOM_SECRET
