---
import { Image } from 'astro:assets';
import contactBg from '../../assets/images/photo_2026-06-04_00-08-20.jpg';
---

<section class="cta-section" id="contacts">
  <div class="cta-bg">
    <Image src={contactBg} alt="" width={1920} height={1080} loading="lazy" />
    <div class="cta-bg-overlay"></div>
  </div>
  <div class="cta-grid">
    <div class="cta-text">
      <span class="section-label">КОНТАКТЫ</span>
      <h2 class="cta-title">Обсудим ваш проект</h2>
      <p class="cta-desc">Оставьте заявку — мы свяжемся в течение 24 часов и подготовим индивидуальное предложение под ваши задачи.</p>
      <div class="cta-messengers">
        <span class="messengers-label">Быстрая связь</span>
        <div class="messengers-row">
          <a href="https://wa.me/79881590888" class="messenger-btn whatsapp" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.13 1.585 5.929L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>WhatsApp</span>
          </a>
          <a href="https://t.me/gyurjyan" class="messenger-btn telegram" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.062 3.345-.48.33-.913.49-1.303.48-.428-.008-1.252-.241-1.865-.44-.752-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            <span>Telegram</span>
          </a>
        </div>
        <div class="phone-toggle-wrap">
          <button class="messenger-btn phone-toggle" type="button" aria-expanded="false">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            <span>Позвонить</span>
          </button>
          <div class="phone-dropdown" hidden>
            <a href="tel:+79881590888" class="messenger-btn phone">Россия</a>
            <a href="tel:+37494751892" class="messenger-btn phone">Армения</a>
          </div>
        </div>
      </div>
    </div>
    <div class="cta-form-wrapper">
      <form class="cta-form" id="contactForm" action="#" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Имя</label>
            <input type="text" id="name" name="name" placeholder="Ваше имя" required>
          </div>
          <div class="form-group">
            <label for="phone">Телефон</label>
            <input type="tel" id="phone" name="phone" placeholder="+374 ..." required>
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com">
        </div>
        <div class="form-group">
          <label for="service">Интересующее направление</label>
          <select id="service" name="service">
            <option value="">Выберите направление</option>
            <option value="construction">Строительство</option>
            <option value="design">Дизайн и отделка</option>
            <option value="land">Земельные участки</option>
            <option value="tourism">Туризм</option>
            <option value="architecture">Архитектура</option>
            <option value="investment">Инвестиции</option>
            <option value="complex">Комплексный проект</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">О проекте</label>
          <textarea id="message" name="message" rows="4" placeholder="Расскажите кратко о вашем проекте или задаче..."></textarea>
        </div>
        <button type="submit" class="form-submit">
          <span>ОТПРАВИТЬ ЗАЯВКУ</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
  <div class="cta-footer-bar">
    <div class="cta-footer-brand">
      <span class="cta-footer-logo">INTEGRA KOTOVA</span>
      <p>Строительство. Дизайн. Земля. Туризм. Инвестиции.</p>
    </div>
    <div class="cta-footer-col">
      <h4>Адрес</h4>
      <p>Ереван, Армения<br>ул. Таманяна, 1</p>
    </div>
    <div class="cta-footer-col">
      <h4>Контакты</h4>
      <p><a href="mailto:info@gyurjyan.com">info@gyurjyan.com</a></p>
      <p><a href="tel:+79881590888">+7 988 159-08-88</a></p>
      <p><a href="tel:+37494751892">+374 94 751-892</a></p>
    </div>
    <div class="cta-footer-col">
      <h4>Соцсети</h4>
      <p><a href="#">Instagram</a></p>
      <p><a href="#">LinkedIn</a></p>
    </div>
  </div>
</section>

<style>
  .cta-section {
    view-transition-name: contact;
  }
</style>
