---
import { Image } from 'astro:assets';
import project0 from '../../assets/images/photo_2026-06-04_00-08-25.jpg';
import project1 from '../../assets/images/photo_2026-06-04_00-08-25 (2).jpg';
import project2 from '../../assets/images/photo_2026-06-04_00-08-26.jpg';
import project3 from '../../assets/images/photo_2026-06-04_00-08-24 (2).jpg';
import project4 from '../../assets/images/photo_2026-06-04_00-08-24.jpg';
import project5 from '../../assets/images/photo_2026-06-04_00-08-34.jpg';
import project6 from '../../assets/images/photo_2026-06-04_00-08-26.jpg';
import project7 from '../../assets/images/photo_2026-06-04_00-08-30.jpg';
---

<section class="projects section" id="projects">
  <div class="container">
    <div class="section-header center">
      <span class="section-label">ПОРТФОЛИО</span>
      <h2 class="section-title">Реализованные проекты</h2>
      <p class="section-desc">Объекты, которые мы создали от концепции до сдачи</p>
    </div>
    <div class="projects-slider" id="projectsSlider">
      <div class="projects-slider-track">
        <div class="project-slide active" data-index="0">
          <Image src={project0} alt="Phuket Villa" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">AG Club Villas</span>
            <h3 class="project-slide-name">26 премиальных вилл</h3>
            <p class="project-slide-loc">Пхукет, Таиланд — инвестиции от $6.6M</p>
          </div>
        </div>
        <div class="project-slide" data-index="1">
          <Image src={project1} alt="Sochi Villa" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Вилла</span>
            <h3 class="project-slide-name">Sochi Hillside</h3>
            <p class="project-slide-loc">Сочи, Россия</p>
          </div>
        </div>
        <div class="project-slide" data-index="2">
          <Image src={project2} alt="Krasnodar Estate" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Резиденция</span>
            <h3 class="project-slide-name">Krasnodar Estate</h3>
            <p class="project-slide-loc">Краснодар, Россия</p>
          </div>
        </div>
        <div class="project-slide" data-index="3">
          <Image src={project3} alt="Moscow Tower" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Апарт-отель</span>
            <h3 class="project-slide-name">Moscow Sky</h3>
            <p class="project-slide-loc">Москва, Россия</p>
          </div>
        </div>
        <div class="project-slide" data-index="4">
          <Image src={project4} alt="SPB Residence" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Резиденция</span>
            <h3 class="project-slide-name">Neva Premium</h3>
            <p class="project-slide-loc">Санкт-Петербург, Россия</p>
          </div>
        </div>
        <div class="project-slide" data-index="5">
          <Image src={project5} alt="Villa Complex" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Виллы</span>
            <h3 class="project-slide-name">Villa Collection</h3>
            <p class="project-slide-loc">Премиум виллы под ключ</p>
          </div>
        </div>
        <div class="project-slide" data-index="6">
          <Image src={project6} alt="Monolith" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Монолит</span>
            <h3 class="project-slide-name">Monolith Plus</h3>
            <p class="project-slide-loc">Монолитное строительство</p>
          </div>
        </div>
        <div class="project-slide" data-index="7">
          <Image src={project7} alt="Yerevan Tourism" width={1000} height={420} loading="lazy" />
          <div class="project-slide-overlay">
            <span class="project-slide-tag">Туризм</span>
            <h3 class="project-slide-name">Yerevan Tourism Hub</h3>
            <p class="project-slide-loc">Ереван, Армения — туристический бизнес под ключ</p>
          </div>
        </div>
      </div>
      <div class="projects-slider-nav">
        <button class="project-slider-btn prev" aria-label="Previous">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="project-slider-dots">
          <span class="dot active"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <button class="project-slider-btn next" aria-label="Next">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>
