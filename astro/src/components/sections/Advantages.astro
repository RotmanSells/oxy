---
import { Image } from 'astro:assets';
import advantagesHeroBg from '../../assets/images/photo_2026-06-04_00-08-23.jpg';
---

<section class="advantages" id="advantages">
  <div class="advantages-hero">
    <Image class="advantages-hero-bg" src={advantagesHeroBg} alt="" width={1920} height={1080} loading="lazy" />
    <div class="advantages-hero-overlay"></div>
    <div class="advantages-hero-content">
      <span class="section-label">ПОЧЕМУ МЫ</span>
      <h2 class="section-title">Преимущества работы с INTEGRA KOTOVA</h2>
      <p class="section-desc">Шесть причин выбрать нас для вашего следующего проекта</p>
    </div>
  </div>
  <div class="advantages-cards-wrap">
    <div class="container">
      <div class="advantages-grid">
        <div class="advantage-item">
          <div class="advantage-glass">
            <div class="advantage-visual">
              <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=500" alt="Команда" width={500} height={200} loading="lazy" />
            </div>
            <div class="advantage-body">
              <h3 class="advantage-title">Единая команда</h3>
              <p class="advantage-desc">Все специалисты — от аналитиков до прорабов — работают в одной компании без посредников.</p>
            </div>
          </div>
        </div>
        <div class="advantage-item">
          <div class="advantage-glass">
            <div class="advantage-visual">
              <img src="https://images.unsplash.com/photo-1506784983877-45594efa4cbe?w=500" alt="Сроки" width={500} height={200} loading="lazy" />
            </div>
            <div class="advantage-body">
              <h3 class="advantage-title">Фиксированные сроки</h3>
              <p class="advantage-desc">Гарантируем соблюдение календарных графиков с финансовой ответственностью за просрочку.</p>
            </div>
          </div>
        </div>
        <div class="advantage-item">
          <div class="advantage-glass">
            <div class="advantage-visual">
              <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=500" alt="Прозрачность" width={500} height={200} loading="lazy" />
            </div>
            <div class="advantage-body">
              <h3 class="advantage-title">Прозрачность</h3>
              <p class="advantage-desc">Онлайн-отчётность, еженедельные сводки и полная финансовая прозрачность на каждом этапе.</p>
            </div>
          </div>
        </div>
        <div class="advantage-item">
          <div class="advantage-glass">
            <div class="advantage-visual">
              <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=500" alt="Качество" width={500} height={200} loading="lazy" />
            </div>
            <div class="advantage-body">
              <h3 class="advantage-title">Премьер-качество</h3>
              <p class="advantage-desc">Проверенные материалы, авторский надзор и многоступенчатый контроль качества.</p>
            </div>
          </div>
        </div>
        <div class="advantage-item">
          <div class="advantage-glass">
            <div class="advantage-visual">
              <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=500" alt="Цикл" width={500} height={200} loading="lazy" />
            </div>
            <div class="advantage-body">
              <h3 class="advantage-title">Полный цикл</h3>
              <p class="advantage-desc">От идеи до операционного запуска — берём на себя каждый этап под ключ.</p>
            </div>
          </div>
        </div>
        <div class="advantage-item">
          <div class="advantage-glass">
            <div class="advantage-visual">
              <img src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?w=500" alt="Мир" width={500} height={200} loading="lazy" />
            </div>
            <div class="advantage-body">
              <h3 class="advantage-title">Международный опыт</h3>
              <p class="advantage-desc">Проекты в Армении, России, Тайланде, Казахстане.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
