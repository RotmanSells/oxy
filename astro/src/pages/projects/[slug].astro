---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const categoryLabels: Record<string, string> = {
  investments: 'Инвестиции',
  architecture: 'Архитектура',
  construction: 'Строительство',
  tourism: 'Туризм',
  design: 'Дизайн',
  supply: 'Снабжение',
};
---

<BaseLayout
  title={`${project.data.title} — INTEGRA KOTOVA`}
  description={project.data.description}
  image={project.data.image}
  url={`/projects/${project.id}`}
>
  <main class="project-page">
    <div class="project-hero">
      <div class="project-hero-image">
        <img src={project.data.image} alt={project.data.title} loading="eager" />
      </div>
      <div class="project-hero-overlay"></div>
      <div class="project-hero-content">
        <span class="project-category">{categoryLabels[project.data.category] || project.data.category}</span>
        <h1 class="project-title">{project.data.title}</h1>
        <p class="project-location">{project.data.location}</p>
        {project.data.year && <span class="project-year">{project.data.year}</span>}
      </div>
    </div>

    <div class="project-body container">
      <div class="project-info">
        <div class="project-meta">
          <div class="meta-item">
            <span class="meta-label">Категория</span>
            <span class="meta-value">{categoryLabels[project.data.category] || project.data.category}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Локация</span>
            <span class="meta-value">{project.data.location}</span>
          </div>
          {project.data.year && (
            <div class="meta-item">
              <span class="meta-label">Год</span>
              <span class="meta-value">{project.data.year}</span>
            </div>
          )}
        </div>
        <div class="project-description">
          <p>{project.data.description}</p>
        </div>
      </div>

      {project.data.images.length > 0 && (
        <div class="project-gallery">
          {project.data.images.map((img: string, i: number) => (
            <div class="gallery-item">
              <img src={img} alt={`${project.data.title} — фото ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
            </div>
          ))}
        </div>
      )}

      <div class="project-content prose">
        <Content />
      </div>

      <div class="project-actions">
        <a href="/#projects" class="btn-back">← К проектам</a>
        <a href="/" class="btn-home">На главную</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .project-page {
    min-height: 100vh;
    padding-top: 0;
  }

  .project-hero {
    position: relative;
    height: 70vh;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .project-hero-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .project-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.4) 100%);
    z-index: 1;
  }

  .project-hero-content {
    position: relative;
    z-index: 2;
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .project-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent, #c9a96e);
    margin-bottom: 1rem;
  }

  .project-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    color: #fff;
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  .project-location {
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    margin: 0 0 0.5rem;
  }

  .project-year {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    font-weight: 500;
  }

  .project-body {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .project-info {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .project-info {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .meta-value {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
  }

  .project-description p {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
    margin: 0;
  }

  .project-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .project-gallery {
      grid-template-columns: 1fr;
    }
  }

  .gallery-item {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(255,255,255,0.03);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  .project-content {
    max-width: 720px;
    margin: 0 auto 4rem;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
  }

  .project-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .project-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .btn-back,
  .btn-home {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .btn-back {
    color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .btn-back:hover {
    border-color: var(--accent, #c9a96e);
    color: var(--accent, #c9a96e);
  }

  .btn-home {
    background: var(--accent, #c9a96e);
    color: #000;
  }

  .btn-home:hover {
    opacity: 0.9;
  }
</style>
