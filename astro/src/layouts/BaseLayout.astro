---
import '../styles/global.css';
import { Image } from 'astro:assets';
import SEO from '../components/layout/SEO.astro';
import imgHero from '../assets/images/photo_2026-06-04_00-08-30.jpg';
import imgAbout from '../assets/images/photo_2026-06-04_00-08-33.jpg';
import imgProjects from '../assets/images/photo_2026-06-04_00-08-34.jpg';
import imgServices from '../assets/images/photo_2026-06-04_00-08-35.jpg';
import imgSupply from '../assets/images/photo_2026-06-04_00-08-22.jpg';
import imgAdvantages from '../assets/images/photo_2026-06-04_00-08-23.jpg';
import imgTourism from '../assets/images/photo_2026-06-04_00-08-37.jpg';
import imgAgclub from '../assets/images/photo_2026-06-03_02-12-27.jpg';
import imgPartners from '../assets/images/photo_2026-06-04_00-08-20.jpg';
import Preloader from '../components/islands/Preloader.jsx';
import AppCore from '../components/islands/AppCore.jsx';
import ScrollAnimations from '../components/islands/ScrollAnimations.jsx';
import HeroFacts from '../components/islands/HeroFacts.jsx';
import ProjectsSlider from '../components/islands/ProjectsSlider.jsx';
import SupplyCarousel from '../components/islands/SupplyCarousel.jsx';
import Lightbox from '../components/islands/Lightbox.jsx';
import ContactForm from '../components/islands/ContactForm.jsx';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: string;
  noindex?: boolean;
}

const {
  title = 'INTEGRA KOTOVA — Строительство. Дизайн. Земля. Туризм. Инвестиции.',
  description = 'От идеи до управления активами — девелопмент полного цикла: строительство, дизайн, земля, туризм и инвестиции.',
  image,
  url = Astro.url.pathname,
  lang = 'ru',
  noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <SEO title={title} description={description} image={image} url={url} lang={lang} noindex={noindex} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="loading">
  <!-- Preloader -->
  <div class="preloader" id="preloader">
    <div class="preloader-particles"></div>
    <div class="preloader-content">
      <div class="preloader-logo">
        <span class="preloader-brand">INTEGRA KOTOVA</span>
        <span class="preloader-tagline">Строительство. Дизайн. Земля. Туризм. Инвестиции.</span>
      </div>
      <div class="preloader-bar-wrap">
        <div class="preloader-bar" id="preloaderBar"></div>
      </div>
      <div class="preloader-status">
        <span class="preloader-text" id="preloaderText">Загрузка</span>
        <span class="preloader-dots"><span>.</span><span>.</span><span>.</span></span>
        <span class="preloader-percent" id="preloaderPercent">0%</span>
      </div>
    </div>
    <div class="preloader-grid"></div>
  </div>

  <!-- Section Images Layer -->
  <div class="section-images-layer" id="sectionImagesLayer">
    <div class="section-img active" data-section="hero">
      <Image src={imgHero} alt="" width={1920} height={1080} loading="eager" fetchpriority="high" sizes="100vw" quality={80} widths={[640, 960, 1280, 1920]} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="about">
      <Image src={imgAbout} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="projects">
      <Image src={imgProjects} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="services">
      <Image src={imgServices} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="supply">
      <Image src={imgSupply} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="advantages">
      <Image src={imgAdvantages} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="tourism">
      <Image src={imgTourism} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="agclub">
      <Image src={imgAgclub} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="partners">
      <Image src={imgPartners} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
    <div class="section-img" data-section="contacts">
      <Image src={imgPartners} alt="" width={1920} height={1080} loading="lazy" sizes="100vw" quality={80} />
      <div class="section-img-overlay"></div>
    </div>
  </div>

  <!-- Overlay -->
  <div class="overlay"></div>

  <slot />

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" aria-label="Закрыть">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <button class="lightbox-nav prev" aria-label="Previous">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="lightbox-nav next" aria-label="Next">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="lightbox-content">
      <img src="" alt="" id="lightboxImg">
    </div>
    <div class="lightbox-counter">
      <span id="lightboxCurrent">1</span> / <span id="lightboxTotal">3</span>
    </div>
  </div>

  <Preloader client:load />
  <AppCore client:load />
  <ScrollAnimations client:visible />
  <HeroFacts client:visible />
  <ProjectsSlider client:visible />
  <SupplyCarousel client:visible />
  <Lightbox client:visible />
  <ContactForm client:visible />
</body>
</html>
