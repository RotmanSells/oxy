PORT=3000

# Telegram Bot — создайте бота у @BotFather, получите токен
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Опционально: fallback ID, если никто не написал боту /start
# Основной способ: админ пишет боту /start и подписывается на заявки
# Узнать ID можно у @userinfobot или @getidsbot
CHAT_ID=

# Разрешённые origin для CORS (ваш фронтенд)
CORS_ORIGIN=https://your-site.vercel.app

# Для продакшена (опционально)
NODE_ENV=production