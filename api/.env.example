PORT=3000

# Telegram Bot — создайте бота у @BotFather, получите токен
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ID чата/группы/канала, куда приходят заявки
# Узнать можно у @userinfobot или @getidsbot
CHAT_ID=YOUR_CHAT_ID_HERE

# Разрешённые origin для CORS (ваш фронтенд)
CORS_ORIGIN=https://your-site.vercel.app

# Для продакшена (опционально)
NODE_ENV=production