PORT=3000

# Telegram Bot — создайте бота у @BotFather, получите токен
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Fallback ID администратора, если никто не написал боту /start
# Узнать ID можно у @userinfobot или @getidsbot
CHAT_ID=

# OpenAI API для AI-аналитики сайта
OPENAI_API_KEY=
OPENAI_MODEL=minimax-m2
OPENAI_BASE_URL=https://api.hydraai.ru/v1

# Разрешённый origin фронтенда
CORS_ORIGIN=https://your-site.vercel.app
SITE_URL=https://your-site.vercel.app

# SQLite
DB_PATH=./data/leads.db

# Резерв для закрытых админских endpoint'ов в будущей админке
ADMIN_SECRET=change-me

NODE_ENV=production
